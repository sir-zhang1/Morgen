---
import Section from "./Section.astro";
import type { AbstractParagraph } from "@types";

interface Props {
  paragraphs: AbstractParagraph[];
}

const { paragraphs } = Astro.props;

const segmentClass = {
  text: "",
  metric: "font-semibold text-white tabular-nums",
  product: "font-medium text-white",
  link: "text-primary underline-offset-2 hover:underline",
} as const;
---

<Section text="Abstract" href="abstract">
  <div class="max-w-[65ch] space-y-8 md:space-y-10">
    {
      paragraphs.map(({ segments }) => (
        <p class="text-base leading-[1.8] text-neutral md:text-[1.0625rem]">
          {segments.map((segment) => {
            if (segment.kind === "link") {
              return (
                <a
                  class={segmentClass.link}
                  href={segment.href}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {segment.text}
                </a>
              );
            }
            return (
              <span class={segmentClass[segment.kind]}>{segment.value}</span>
            );
          })}
        </p>
      ))
    }
  </div>
</Section>
