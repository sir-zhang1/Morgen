---
import Section from "./Section.astro";
import type { ComputeEnvironmentProps } from "@types";
import { withBase } from "../lib/paths";

type Props = ComputeEnvironmentProps;

const {
  axioms,
  image,
  stackTags,
  sectionTitle = "First Principles",
  sectionHref = "about",
} = Astro.props;
const imageSrc = withBase(image);
---

<Section text={sectionTitle} href={sectionHref}>
  <div class="flex flex-col items-center gap-12 md:flex-row md:items-start md:gap-8">
    <div class="w-full max-w-[58ch] flex-1">
      <ol class="list-none space-y-8 md:space-y-10">
        {
          axioms.map(({ text }) => (
            <li>
              <p class="text-base leading-[1.8] text-neutral md:text-lg md:leading-[1.75]">
                <span class="font-serif text-xl font-semibold text-primary md:text-2xl">
                  {text.charAt(0)}
                </span>
                {text.slice(1)}
              </p>
            </li>
          ))
        }
      </ol>
      {
        stackTags && (
          <p class="mt-10 text-sm leading-relaxed font-medium tracking-wide text-primary md:mt-12">
            {stackTags}
          </p>
        )
      }
    </div>
    <div class="h-80 w-64 shrink-0 rotate-[5deg] bg-white p-4 md:rotate-[7deg]">
      <img
        class="h-full w-full object-cover"
        src={imageSrc}
        width="260"
        height="320"
        alt="Morgen"
        loading="lazy"
      />
    </div>
  </div>
</Section>
