---
import Section from "./Section.astro";
import CapabilitiesCloud from "./CapabilitiesCloud.astro";
import type { WorkContent } from "@types";

interface Props {
  work: WorkContent;
}

const { work } = Astro.props;
const { capabilities, implementation, achievements } = work;

const workSubnav = [
  { id: "capabilities", label: "Capabilities" },
  { id: "implementation", label: "Implementation" },
  { id: "achievements", label: "Achievements" },
] as const;

const pillarDomId = (id: string) => `pillar-${id}`;
---

<Section text="Work" href="work">
  <nav
    class="work-subnav -mt-4 mb-14 flex gap-2 overflow-x-auto pb-1 md:mb-16"
    aria-label="Work sections"
  >
    {
      workSubnav.map(({ id, label }) => (
        <a
          href={`#${id}`}
          class="work-subnav-link shrink-0 rounded-full border border-white/15 px-4 py-2 text-sm font-medium tracking-wide text-neutral transition-colors hover:border-primary/40 hover:text-white"
          data-work-target={id}
        >
          {label}
        </a>
      ))
    }
  </nav>

  <section id="capabilities" class="scroll-mt-28 pb-20 md:pb-24">
    <h3
      class="mb-8 font-serif text-2xl font-semibold tracking-tight text-white md:text-3xl"
    >
      Capabilities
    </h3>
    <CapabilitiesCloud capabilities={capabilities} />
  </section>

  <section
    id="implementation"
    class="scroll-mt-28 border-t border-white/10 pb-20 pt-20 md:pb-24 md:pt-24"
  >
    <h3
      class="mb-10 font-serif text-2xl font-semibold tracking-tight text-white md:mb-12 md:text-3xl"
    >
      Implementation
    </h3>

    <div class="implementation-pillars">
      {
        implementation.pillars.map(({ id, title, lead, stages, points }) => (
          <article id={pillarDomId(id)} class="implementation-pillar">
            <h4 class="implementation-pillar__title">{title}</h4>
            <p class="implementation-pillar__lead">{lead}</p>
            {
              stages && stages.length > 0 && (
                <ul class="implementation-pillar__list" role="list">
                  {stages.map(({ version, name, text }) => (
                    <li class="implementation-pillar__item implementation-pillar__item--stage">
                      <span class="implementation-pillar__version">{version}</span>
                      <span class="implementation-pillar__item-text">
                        <strong>{name}</strong>
                        <span class="implementation-pillar__sep" aria-hidden="true">
                          ?
                        </span>
                        {text}
                      </span>
                    </li>
                  ))}
                </ul>
              )
            }
            {
              points && points.length > 0 && (
                <ul class="implementation-pillar__list" role="list">
                  {points.map((point) => (
                    <li class="implementation-pillar__item">
                      <span class="implementation-pillar__item-text">{point}</span>
                    </li>
                  ))}
                </ul>
              )
            }
          </article>
        ))
      }
    </div>

    <header class="journey-header">
      <p class="journey-header__eyebrow">User journey</p>
    </header>

    <div class="journey-snake" aria-label="User journey steps">
      <div class="journey-row journey-row--top">
        <ol class="journey-row__track" role="list">
          {
            implementation.journey.slice(0, 4).map(({ label, body }, index) => (
              <li class="journey-node" role="listitem">
                <div class="journey-node__marker">
                  <span class="journey-node__index" aria-hidden="true">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                </div>
                <div class="journey-node__content">
                  <p class="journey-node__label">{label}</p>
                  <p class="journey-node__body">{body}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="journey-row journey-row--bottom">
        <ol class="journey-row__track" role="list">
          {
            implementation.journey.slice(4, 8).map(({ label, body }, index) => (
              <li class="journey-node" role="listitem">
                <div class="journey-node__marker">
                  <span class="journey-node__index" aria-hidden="true">
                    {String(index + 5).padStart(2, "0")}
                  </span>
                </div>
                <div class="journey-node__content">
                  <p class="journey-node__label">{label}</p>
                  <p class="journey-node__body">{body}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <section
    id="achievements"
    class="scroll-mt-28 border-t border-white/10 pt-20 md:pt-24"
  >
    <h3
      class="mb-2 font-serif text-2xl font-semibold tracking-tight text-white md:text-3xl"
    >
      Achievements
    </h3>
    <p class="mb-10 text-base text-neutral/80 italic md:mb-12">
      {achievements.headline}
    </p>

    <div class="mb-8 grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-4">
      {
        achievements.primary.map(({ value, label }) => (
          <div class="text-center sm:text-left">
            <p class="mb-1 font-serif text-2xl font-bold text-white tabular-nums md:text-3xl">
              {value}
            </p>
            <p class="text-xs leading-snug text-neutral/80 md:text-sm">
              {label}
            </p>
          </div>
        ))
      }
    </div>

    {
      achievements.secondary.length > 0 && (
        <div class="flex flex-wrap gap-x-10 gap-y-4 border-t border-white/10 pt-8">
          {achievements.secondary.map(({ value, label }) => (
            <div>
              <span class="mr-2 font-serif text-lg font-semibold text-white tabular-nums">
                {value}
              </span>
              <span class="text-sm text-neutral/75">{label}</span>
            </div>
          ))}
        </div>
      )
    }
  </section>
</Section>

<script>
  const subnavLinks = document.querySelectorAll<HTMLAnchorElement>(
    ".work-subnav-link",
  );
  const workSectionIds = ["capabilities", "implementation", "achievements"];

  const activeSubnavClasses = [
    "border-primary/50",
    "bg-primary/10",
    "text-white",
  ];

  const setActiveWorkSubnav = (sectionId: string) => {
    subnavLinks.forEach((link) => {
      const isActive = link.getAttribute("data-work-target") === sectionId;
      activeSubnavClasses.forEach((cls) =>
        link.classList.toggle(cls, isActive),
      );
    });
  };

  const updateWorkSubnavFromScroll = () => {
    const scrollMarker = window.scrollY + window.innerHeight * 0.32;
    let activeId = workSectionIds[0]!;

    for (const id of workSectionIds) {
      const el = document.getElementById(id);
      if (el && el.offsetTop <= scrollMarker) {
        activeId = id;
      }
    }

    setActiveWorkSubnav(activeId);
  };

  let workScrollTicking = false;
  const onWorkScroll = () => {
    if (workScrollTicking) return;
    workScrollTicking = true;
    requestAnimationFrame(() => {
      updateWorkSubnavFromScroll();
      workScrollTicking = false;
    });
  };

  subnavLinks.forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const id = link.getAttribute("data-work-target");
      const target = id ? document.getElementById(id) : null;
      if (target) {
        target.scrollIntoView({ behavior: "smooth", block: "start" });
        history.replaceState(null, "", `#${id}`);
      }
    });
  });

  window.addEventListener("scroll", onWorkScroll, { passive: true });
  window.addEventListener("resize", onWorkScroll, { passive: true });
  updateWorkSubnavFromScroll();
</script>

<style>
  .implementation-pillars {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .implementation-pillars {
      gap: 1.5rem;
      grid-auto-rows: 1fr;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-bottom: 3rem;
    }
  }

  .implementation-pillar {
    border-top: 1px solid rgb(255 255 255 / 0.12);
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-top: 1.25rem;
  }

  .implementation-pillar__title {
    color: var(--color-primary);
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    line-height: 1.3;
    margin: 0 0 0.75rem;
  }

  .implementation-pillar__lead {
    color: color-mix(in srgb, var(--color-neutral) 92%, transparent);
    font-size: 0.875rem;
    line-height: 1.65;
    margin: 0 0 1rem;
    min-height: 4.5rem;
  }

  @media (min-width: 768px) {
    .implementation-pillar__lead {
      min-height: 5.25rem;
    }
  }

  .implementation-pillar__list {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.625rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .implementation-pillar__item {
    align-items: flex-start;
    display: flex;
    gap: 0.625rem;
    margin: 0;
  }

  .implementation-pillar__item--stage {
    gap: 0.5rem;
  }

  .implementation-pillar__version {
    color: var(--color-primary);
    flex-shrink: 0;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    line-height: 1.65;
    min-width: 1.5rem;
  }

  .implementation-pillar__item-text {
    color: color-mix(in srgb, var(--color-neutral) 88%, transparent);
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  .implementation-pillar__item-text strong {
    color: var(--color-white);
    font-weight: 600;
  }

  .implementation-pillar__sep {
    color: color-mix(in srgb, var(--color-neutral) 50%, transparent);
    margin: 0 0.25rem;
  }

  .implementation-pillar__item:not(.implementation-pillar__item--stage) {
    padding-left: 0.125rem;
  }

  .implementation-pillar__item:not(.implementation-pillar__item--stage)::before {
    background: var(--color-primary);
    border-radius: 9999px;
    content: "";
    flex-shrink: 0;
    height: 4px;
    margin-top: 0.55rem;
    width: 4px;
  }

  .journey-header {
    margin-bottom: 1.25rem;
    padding-top: 0.25rem;
  }

  @media (min-width: 768px) {
    .journey-header {
      margin-bottom: 1.5rem;
    }
  }

  .journey-header__eyebrow {
    color: color-mix(in srgb, var(--color-neutral) 75%, transparent);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    margin: 0;
    text-transform: uppercase;
  }

  .journey-snake {
    position: relative;
  }

  .journey-row__track {
    display: grid;
    gap: 0;
    grid-template-columns: 1fr;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .journey-node {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 3.25rem 1fr;
    padding: 0 0 1.5rem;
    position: relative;
  }

  .journey-row__track .journey-node:last-child {
    padding-bottom: 0;
  }

  .journey-node__marker {
    align-items: flex-start;
    display: flex;
    justify-content: flex-end;
    padding-right: 0.75rem;
    padding-top: 0.125rem;
    position: relative;
  }

  .journey-node__marker::before {
    background: color-mix(in srgb, var(--color-primary) 35%, transparent);
    bottom: -1.5rem;
    content: "";
    left: 50%;
    position: absolute;
    top: 1.75rem;
    transform: translateX(-50%);
    width: 1px;
  }

  .journey-row__track .journey-node:last-child .journey-node__marker::before {
    display: none;
  }

  .journey-node__index {
    color: var(--color-primary);
    display: block;
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .journey-node__content {
    border-left: 1px solid rgb(255 255 255 / 0.12);
    min-width: 0;
    padding-left: 1rem;
  }

  .journey-node__label {
    color: var(--color-white);
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    line-height: 1.35;
    margin: 0 0 0.375rem;
  }

  .journey-node__body {
    color: color-mix(in srgb, var(--color-neutral) 90%, transparent);
    font-size: 0.875rem;
    line-height: 1.65;
    margin: 0;
  }

  @media (min-width: 768px) {
    .journey-row--top {
      margin-bottom: 1.25rem;
    }

    .journey-row__track {
      gap: 1.25rem 1.5rem;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .journey-node {
      padding-bottom: 0;
    }

    .journey-node__marker::before {
      display: none;
    }
  }

  @media (min-width: 1024px) {
    .journey-row--top {
      margin-bottom: 1.5rem;
    }

    .journey-row__track {
      gap: 1.5rem 2rem;
      grid-auto-rows: 1fr;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .journey-node {
      display: flex;
      flex-direction: column;
      gap: 0;
      min-height: 8.75rem;
      padding: 0;
    }

    .journey-node__marker {
      justify-content: flex-start;
      margin-bottom: 0.75rem;
      min-height: 1.25rem;
      padding-right: 0;
    }

    .journey-node__index {
      font-size: 1.375rem;
    }

    .journey-node__content {
      border-left: none;
      padding-left: 0;
    }
  }
</style>
