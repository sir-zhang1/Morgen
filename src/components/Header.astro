---
import Menu from "@icons/Menu.astro";
import type { HeaderProps } from "@types";
import { withBase } from "../lib/paths";

type Props = HeaderProps;

const { siteLogo, navLinks } = Astro.props;
const logoSrc = withBase(siteLogo);

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base.slice(0, -1) : base;

const resolveHref = (href: string) => {
  if (href === "/") return base;
  if (href.startsWith("/")) return `${basePath}${href}`;
  return href;
};
---

<header
  class="sticky top-0 z-50 mx-auto flex max-w-5xl animate-slide-in justify-between bg-black px-5 py-6"
>
  <a href={base} aria-label="Home link">
    <img
      class="rounded-full"
      src={logoSrc}
      width="45"
      height="45"
      alt="website logo"
    />
  </a>

  <button
    type="button"
    id="menu-button"
    class="px-1.5 text-neutral sm:hidden"
    aria-expanded="false"
    aria-controls="main-menu"
  >
    <Menu />
  </button>

  <nav
    class="absolute top-20 right-5 hidden rounded-xl border border-neutral/40 bg-black px-4 py-5 text-neutral sm:static sm:block sm:border-0 sm:bg-transparent sm:p-0"
    id="main-menu"
  >
    <ul class="gap-2 sm:flex">
      {
        navLinks.map((link) => {
          const sectionId = link.href.includes("#")
            ? link.href.split("#").pop()!
            : "hero";
          return (
            <li class="relative">
              <a
                class="nav-item relative block p-2 text-sm leading-none font-medium tracking-wide transition-all duration-500 after:absolute after:bottom-0 after:left-2/4 after:h-2 after:w-1 after:-translate-x-2/4 after:text-primary after:opacity-0 after:content-['•'] hover:text-white"
                href={resolveHref(link.href)}
                data-section-id={sectionId}
              >
                {link.text}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<script>
  const button = document.querySelector("#menu-button");
  const menu = document.querySelector("#main-menu");
  const navItems = document.querySelectorAll<HTMLAnchorElement>(
    "#main-menu > ul > li > a",
  );

  const toggleMenu = () => {
    menu?.classList.toggle("hidden");
    const isHidden = menu?.classList.contains("hidden");
    button?.setAttribute("aria-expanded", `${!isHidden}`);
  };

  button?.addEventListener("click", toggleMenu);
  navItems.forEach((item) => {
    item?.addEventListener("click", toggleMenu);
  });

  const activeClasses = ["text-white", "after:opacity-100"];

  const setActiveNav = (sectionId: string) => {
    navItems.forEach((item) => {
      const isActive = item.getAttribute("data-section-id") === sectionId;
      activeClasses.forEach((cls) => item.classList.toggle(cls, isActive));
    });
  };

  const navSectionIds = Array.from(navItems)
    .map((item) => item.getAttribute("data-section-id"))
    .filter((id): id is string => Boolean(id));

  /** Scroll-position spy: Primitives is very tall (sticky cards), so IO max-ratio never picks validation. */
  const updateActiveFromScroll = () => {
    const scrollMarker = window.scrollY + window.innerHeight * 0.28;
    let activeId = navSectionIds[0] ?? "hero";

    for (const id of navSectionIds) {
      const section = document.getElementById(id);
      if (section && section.offsetTop <= scrollMarker) {
        activeId = id;
      }
    }

    setActiveNav(activeId);
  };

  let scrollTicking = false;
  const onScroll = () => {
    if (scrollTicking) return;
    scrollTicking = true;
    requestAnimationFrame(() => {
      updateActiveFromScroll();
      scrollTicking = false;
    });
  };

  window.addEventListener("scroll", onScroll, { passive: true });
  window.addEventListener("resize", onScroll, { passive: true });
  updateActiveFromScroll();

  document.onvisibilitychange = () => {
    if (document.visibilityState === "visible") {
      updateActiveFromScroll();
    }
  };
</script>

<style>
  header {
    animation-timeline: scroll();
    animation-range: 0 650px;
  }
</style>
