---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../lib/paths";

interface Props {
  entry: CollectionEntry<"primitives">;
  prev?: CollectionEntry<"primitives">;
  next?: CollectionEntry<"primitives">;
  index: number;
  total: number;
}

const { entry, prev, next, index, total } = Astro.props;
const { title, role, subtitle, description } = entry.data;
const orderLabel = String(index + 1).padStart(2, "0");
const rajaBg = `url(${withBase("/raja.png")})`;
---

<article class="primitive-page py-16 md:py-24">
  <nav class="mb-12 flex flex-wrap items-center justify-between gap-4">
    <a
      href={`${import.meta.env.BASE_URL}#case`}
      class="primitive-back inline-flex items-center gap-2 rounded-full border border-neutral/30 bg-white/5 px-4 py-2 text-sm leading-none font-medium tracking-wide text-neutral transition-colors hover:border-primary/50 hover:text-white"
    >
      <span aria-hidden="true">←</span>
      Case Analysis
    </a>
    <span class="text-xs leading-none font-medium tracking-[0.14em] text-neutral uppercase">
      {orderLabel} / {String(total).padStart(2, "0")}
    </span>
  </nav>

  <header
    class="primitive-hero relative mb-14 overflow-hidden rounded-2xl border border-neutral/20 bg-[#1c232d]/90 px-7 py-11 md:px-10 md:py-14"
  >
    <div
      class="pointer-events-none absolute inset-0 bg-size-[128px] bg-repeat opacity-[0.06]"
      style={`background-image: ${rajaBg}`}
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute -top-24 -right-24 h-64 w-64 rounded-full bg-primary/10 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="relative z-10">
      <p class="mb-4 text-xs font-medium tracking-[0.16em] text-primary uppercase">
        Core Primitive
      </p>
      {role && (
        <p class="mb-3 text-xs font-medium tracking-[0.12em] text-white/70 uppercase">
          {role}
        </p>
      )}
      <h1
        class="mb-5 font-serif text-3xl leading-[1.08] font-bold tracking-tighter text-white md:text-5xl"
      >
        {title}
      </h1>
      <p class="mb-7 max-w-2xl font-serif text-xl leading-snug font-medium text-primary md:text-2xl">
        {subtitle}
      </p>
      <p class="max-w-2xl border-t border-neutral/20 pt-7 text-base leading-[1.8] text-neutral md:text-[1.0625rem]">
        {description}
      </p>
    </div>
  </header>

  <div
    class="primitive-body rounded-2xl border border-neutral/20 bg-[#1c232d]/50 px-7 py-11 md:px-10 md:py-12"
  >
    <slot />
  </div>

  {
    (prev || next) && (
      <footer class="mt-12 grid gap-4 border-t border-neutral/20 pt-10 sm:grid-cols-2">
        {prev ? (
          <a
            href={withBase(`/primitives/${prev.id}`)}
            class="primitive-nav-card group rounded-xl border border-neutral/20 bg-white/[0.02] p-5 transition-colors hover:border-primary/40 hover:bg-white/[0.04]"
          >
            <span class="mb-2 block text-xs tracking-[0.14em] text-neutral uppercase">
              Previous
            </span>
            <span class="font-serif text-lg leading-snug font-medium text-white group-hover:text-primary">
              {prev.data.title}
            </span>
          </a>
        ) : (
          <div />
        )}
        {next ? (
          <a
            href={withBase(`/primitives/${next.id}`)}
            class="primitive-nav-card group rounded-xl border border-neutral/20 bg-white/[0.02] p-5 text-right transition-colors hover:border-primary/40 hover:bg-white/[0.04] sm:col-start-2"
          >
            <span class="mb-2 block text-xs tracking-[0.14em] text-neutral uppercase">
              Next
            </span>
            <span class="font-serif text-lg leading-snug font-medium text-white group-hover:text-primary">
              {next.data.title}
            </span>
          </a>
        ) : (
          <div />
        )}
      </footer>
    )
  }
</article>
