---
interface Props {
  text: string;
  href: string;
}

const { text, href } = Astro.props;
---

<section id={href} class="py-28 md:py-32">
  <h2
    class="mb-12 font-serif text-4xl leading-[1.08] font-bold tracking-tighter text-white md:mb-14 md:text-5xl"
  >
    {text}
  </h2>
  <slot />
</section>
