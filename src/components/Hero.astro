---
import type { HeroProps } from "@types";

type Props = HeroProps;

const { name, role } = Astro.props;
---

<section class="hero border-b border-white/5 py-32 md:py-40 lg:py-44" id="hero">
  <h1 class="hero-title mb-8 font-serif font-bold tracking-tightest text-white uppercase md:mb-10">
    {name}
  </h1>
  <p class="hero-role max-w-2xl border-l-2 border-primary/60 pl-5 font-medium tracking-wide text-primary md:pl-6">
    {role}
  </p>
</section>

<style>
  .hero-title {
    font-size: clamp(3.5rem, 11vw, 7.5rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
  }

  .hero-role {
    font-size: clamp(1.0625rem, 2.2vw, 1.375rem);
    line-height: 1.65;
  }

  @media (min-width: 1024px) {
    .hero {
      min-height: calc(100vh - 5.5rem);
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-top: 2rem;
      padding-bottom: 3rem;
    }
  }
</style>
