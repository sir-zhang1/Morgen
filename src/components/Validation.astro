---
import Section from "./Section.astro";
import type { ValidationContent } from "@types";

interface Props {
  items: ValidationContent;
}

const { items } = Astro.props;
const { credentials, portfolio } = items;
---

<Section text="Proof of Merit" href="validation">
  <div class="max-w-[65ch]">
    <ol class="mb-16 list-none space-y-8 md:mb-20 md:space-y-10">
      {
        credentials.map(({ text = "", emphasis, suffix = "" }, index) => (
          <li class="grid grid-cols-[2.5rem_1fr] gap-x-4 gap-y-2">
            <span class="font-mono text-sm font-medium text-primary tabular-nums">
              {String(index + 1).padStart(2, "0")}
            </span>
            <div class="text-base leading-[1.75] text-neutral">
              {text}
              {emphasis && (
                <span class="mt-1 block font-serif text-lg font-semibold text-white md:text-xl">
                  {emphasis}
                </span>
              )}
              {suffix && <span>{suffix}</span>}
            </div>
          </li>
        ))
      }
    </ol>

    <div class="border-t border-white/10 pt-14 md:pt-16">
      <p
        class="mb-10 text-xs font-medium tracking-[0.2em] text-neutral/60 uppercase md:mb-12"
      >
        Systems Record
      </p>
      <div class="space-y-12 md:space-y-14">
        {
          portfolio.map(({ code, title, domain, core }) => (
            <article>
              <p class="mb-2 font-mono text-sm tracking-wide text-primary">
                [{code}]
              </p>
              <h3 class="mb-5 font-serif text-xl leading-snug font-semibold text-white md:text-2xl">
                {title}
              </h3>
              <dl class="space-y-3">
                <div class="grid gap-1 md:grid-cols-[5rem_1fr] md:gap-4">
                  <dt class="text-xs font-medium tracking-wide text-neutral/50 uppercase">
                    Domain
                  </dt>
                  <dd class="text-sm leading-relaxed text-neutral/90 italic md:text-base">
                    {domain}
                  </dd>
                </div>
                <div class="grid gap-1 md:grid-cols-[5rem_1fr] md:gap-4">
                  <dt class="text-xs font-medium tracking-wide text-neutral/50 uppercase">
                    Core
                  </dt>
                  <dd class="text-sm leading-relaxed tracking-wide text-neutral/75">
                    {core}
                  </dd>
                </div>
              </dl>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</Section>
