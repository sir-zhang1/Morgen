---
import { SITE_CONTENT } from "@config";
import Hero from "@components/Hero.astro";
import Layout from "@layouts/Layout.astro";
import Work from "@components/Work.astro";
import Background from "@components/Background.astro";
import Primitives from "@components/Primitives.astro";
import ComputeEnvironment from "@components/ComputeEnvironment.astro";

import "../styles/global.css";
---

<Layout>
  <Hero {...SITE_CONTENT.hero} />
  <Work work={SITE_CONTENT.work} />
  <Background items={SITE_CONTENT.validation} />
  <Primitives />
  <ComputeEnvironment {...SITE_CONTENT.compute} />
</Layout>
